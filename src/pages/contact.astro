---
import Layout from '@/layouts/Layout.astro';
import Section from '@/components/Section.astro';
---

<Layout
  title="Contact"
  description="Get in touch with the OceanGliders steering team."
>
  <!-- Page Hero -->
  <div class="bg-ocean-primary text-white">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <p class="section-subheading text-ocean-secondary">Get in Touch</p>
      <h1 class="text-4xl md:text-5xl font-semibold mb-4 leading-tight">Contact Us</h1>
      <p class="text-white/70 text-lg max-w-xl leading-relaxed">
        Whether you're looking to join the network, share data, or ask a scientific question—we'd love to hear from you.
      </p>
    </div>
  </div>

  <Section>
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">
      <!-- Contact form -->
      <div class="lg:col-span-3">
        <h2 class="section-heading mb-8">Send a Message</h2>
        <form id="contact-form" class="space-y-6" novalidate>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="first-name" class="block text-sm font-medium text-ocean-primary mb-2">
                First Name <span class="text-ocean-secondary">*</span>
              </label>
              <input
                id="first-name"
                name="first-name"
                type="text"
                required
                autocomplete="given-name"
                class="w-full px-4 py-3 rounded-lg border border-ocean-primary/20 bg-white text-ocean-primary
                       placeholder-ocean-primary/30 focus:outline-none focus:border-ocean-secondary focus:ring-2
                       focus:ring-ocean-secondary/20 transition"
                placeholder="Jane"
              />
            </div>
            <div>
              <label for="last-name" class="block text-sm font-medium text-ocean-primary mb-2">
                Last Name <span class="text-ocean-secondary">*</span>
              </label>
              <input
                id="last-name"
                name="last-name"
                type="text"
                required
                autocomplete="family-name"
                class="w-full px-4 py-3 rounded-lg border border-ocean-primary/20 bg-white text-ocean-primary
                       placeholder-ocean-primary/30 focus:outline-none focus:border-ocean-secondary focus:ring-2
                       focus:ring-ocean-secondary/20 transition"
                placeholder="Doe"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-ocean-primary mb-2">
              Email Address <span class="text-ocean-secondary">*</span>
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="w-full px-4 py-3 rounded-lg border border-ocean-primary/20 bg-white text-ocean-primary
                     placeholder-ocean-primary/30 focus:outline-none focus:border-ocean-secondary focus:ring-2
                     focus:ring-ocean-secondary/20 transition"
              placeholder="jane.doe@institution.org"
            />
          </div>

          <div>
            <label for="organisation" class="block text-sm font-medium text-ocean-primary mb-2">
              Organisation / Institution
            </label>
            <input
              id="organisation"
              name="organisation"
              type="text"
              autocomplete="organization"
              class="w-full px-4 py-3 rounded-lg border border-ocean-primary/20 bg-white text-ocean-primary
                     placeholder-ocean-primary/30 focus:outline-none focus:border-ocean-secondary focus:ring-2
                     focus:ring-ocean-secondary/20 transition"
              placeholder="National Oceanography Centre"
            />
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium text-ocean-primary mb-2">
              Subject <span class="text-ocean-secondary">*</span>
            </label>
            <select
              id="subject"
              name="subject"
              required
              class="w-full px-4 py-3 rounded-lg border border-ocean-primary/20 bg-white text-ocean-primary
                     focus:outline-none focus:border-ocean-secondary focus:ring-2 focus:ring-ocean-secondary/20 transition"
            >
              <option value="" disabled selected>Select a topic…</option>
              <option value="join">Joining the network</option>
              <option value="data">Data access &amp; management</option>
              <option value="science">Scientific collaboration</option>
              <option value="operations">Glider operations</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-ocean-primary mb-2">
              Message <span class="text-ocean-secondary">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-lg border border-ocean-primary/20 bg-white text-ocean-primary
                     placeholder-ocean-primary/30 focus:outline-none focus:border-ocean-secondary focus:ring-2
                     focus:ring-ocean-secondary/20 transition resize-none"
              placeholder="Tell us how we can help…"
            ></textarea>
          </div>

          <div id="form-status" class="hidden"></div>

          <button type="submit" class="btn-primary w-full sm:w-auto">
            Send Message
          </button>
        </form>
      </div>

      <!-- Contact info -->
      <div class="lg:col-span-2 space-y-4">
        <h2 class="section-heading mb-6">Contact Information</h2>

        <!-- Co-Chairs -->
        <div class="bg-white rounded-xl shadow-md border border-ocean-light/30 p-5 flex gap-4 items-start">
          <div class="w-8 h-8 rounded-lg bg-ocean-secondary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2f9dc0" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <div>
            <p class="font-medium text-ocean-primary text-sm mb-1">Co-Chairs</p>
            <div class="space-y-1">
              <div>
                <span class="text-ocean-primary/60 text-sm">Robert Todd — </span>
                <a href="mailto:rtodd@whoi.edu" class="text-ocean-secondary text-sm hover:underline">rtodd@whoi.edu</a>
              </div>
              <div>
                <span class="text-ocean-primary/60 text-sm">Filipa Carvalho — </span>
                <a href="mailto:filcar@noc.ac.uk" class="text-ocean-secondary text-sm hover:underline">filcar@noc.ac.uk</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Technical Coordinator -->
        <div class="bg-white rounded-xl shadow-md border border-ocean-light/30 p-5 flex gap-4 items-start">
          <div class="w-8 h-8 rounded-lg bg-ocean-secondary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2f9dc0" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <p class="font-medium text-ocean-primary text-sm mb-1">Technical Coordinator</p>
            <div>
              <span class="text-ocean-primary/60 text-sm">Mariarita Caracciolo — </span>
              <a href="mailto:mcaracciolo@wmo.int" class="text-ocean-secondary text-sm hover:underline">mcaracciolo@wmo.int</a>
            </div>
          </div>
        </div>

        <!-- Data Management Lead -->
        <div class="bg-white rounded-xl shadow-md border border-ocean-light/30 p-5 flex gap-4 items-start">
          <div class="w-8 h-8 rounded-lg bg-ocean-secondary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2f9dc0" stroke-width="2">
              <ellipse cx="12" cy="5" rx="9" ry="3"/>
              <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
              <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
            </svg>
          </div>
          <div>
            <p class="font-medium text-ocean-primary text-sm mb-1">Data Management Lead</p>
            <div class="space-y-1">
              <div>
                <span class="text-ocean-primary/60 text-sm">Jennifer Sevadjian — </span>
                <a href="mailto:jpsevadjian@ucsd.edu" class="text-ocean-secondary text-sm hover:underline">jpsevadjian@ucsd.edu</a>
              </div>
              <div>
                <span class="text-ocean-primary/60 text-sm">Emma Gardner — </span>
                <a href="mailto:emmer@noc.ac.uk" class="text-ocean-secondary text-sm hover:underline">emmer@noc.ac.uk</a>
              </div>
            </div>
          </div>
        </div>

        <!-- GitHub -->
        <div class="bg-white rounded-xl shadow-md border border-ocean-light/30 p-5 flex gap-4 items-start">
          <div class="w-8 h-8 rounded-lg bg-ocean-secondary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#2f9dc0">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </div>
          <div>
            <p class="font-medium text-ocean-primary text-sm mb-1">Community on GitHub</p>
            <a href="https://github.com/OceanGlidersCommunity" target="_blank" rel="noopener"
               class="text-ocean-secondary text-sm hover:underline">
              github.com/OceanGlidersCommunity
            </a>
          </div>
        </div>

        <div class="border-t border-ocean-primary/10 pt-6">
          <p class="text-ocean-primary/50 text-sm leading-relaxed">
            OceanGliders is an international programme. We aim to respond to all enquiries within
            5 working days.
          </p>
        </div>
      </div>
    </div>
  </Section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const statusEl = document.getElementById('form-status');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const firstName = (form.elements.namedItem('first-name') as HTMLInputElement).value;
    const lastName  = (form.elements.namedItem('last-name')  as HTMLInputElement).value;
    const email     = (form.elements.namedItem('email')      as HTMLInputElement).value;
    const org       = (form.elements.namedItem('organisation') as HTMLInputElement).value;
    const subject   = (form.elements.namedItem('subject')    as HTMLSelectElement).value;
    const message   = (form.elements.namedItem('message')    as HTMLTextAreaElement).value;

    const body = [
      `From: ${firstName} ${lastName}`,
      `Email: ${email}`,
      org ? `Organisation: ${org}` : '',
      `Topic: ${subject}`,
      '',
      message,
    ].filter(Boolean).join('\n');

    const mailto = `mailto:og-st@groups.wmo.int?subject=${encodeURIComponent(`[OceanGliders] ${subject}`)}&body=${encodeURIComponent(body)}`;
    window.location.href = mailto;

    if (statusEl) {
      statusEl.className = 'mt-2 p-4 rounded-lg bg-ocean-secondary/10 text-ocean-primary text-sm';
      statusEl.textContent = 'Your email client is opening with the message pre-filled. Thank you!';
    }
    form.reset();
  });
</script>
