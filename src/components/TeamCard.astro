---
interface Props {
  name: string;
  role: string;
  institution: string;
  country?: string;
  email?: string;
  imageUrl?: string;
  bio?: string;
  imagePosition?: string;
}

const { name, role, institution, country, email, imageUrl, bio, imagePosition = 'top' } = Astro.props;
const b = import.meta.env.BASE_URL;
const base = b.endsWith('/') ? b : b + '/';
const resolvedImage = imageUrl ? `${base}${imageUrl.replace(/^\//, '')}` : undefined;

const initials = name
  .split(' ')
  .map(n => n[0])
  .slice(0, 2)
  .join('');
---

<div class="glass-card flex flex-col overflow-hidden">
  <div class="w-full aspect-[4/3] bg-ocean-primary/10 overflow-hidden">
    {resolvedImage ? (
      <img
        src={resolvedImage}
        alt={name}
        class="w-full h-full object-cover"
        style={`object-position: ${imagePosition}`}
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-ocean-primary">
        <span class="text-white font-semibold text-4xl">{initials}</span>
      </div>
    )}
  </div>

  <div class="p-5 flex flex-col gap-3 flex-1">
    <div>
      <h3 class="font-semibold text-ocean-primary text-base leading-tight">{name}</h3>
      <p class="text-ocean-secondary text-sm font-medium mt-1">{role}</p>
      <p class="text-ocean-primary/50 text-xs mt-0.5">{institution}{country ? `, ${country}` : ''}</p>
    </div>

    {bio && (
      <p class="text-sm text-ocean-primary/60 leading-relaxed">{bio}</p>
    )}

    {email && (
      <a
        href={`mailto:${email}`}
        class="text-ocean-secondary text-xs hover:text-ocean-primary transition-colors truncate mt-auto pt-1"
      >
        {email}
      </a>
    )}
  </div>
</div>
